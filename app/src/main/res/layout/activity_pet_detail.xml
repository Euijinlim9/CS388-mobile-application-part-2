<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <ImageView
        android:id="@+id/detail_pet_photo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:contentDescription="@string/pet_photo_content_description"
        android:src="@mipmap/ic_launcher_round"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/change_pet_photo_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="@string/change_pet_photo"
        app:layout_constraintTop_toTopOf="@id/detail_pet_photo"
        app:layout_constraintBottom_toBottomOf="@id/detail_pet_photo"
        app:layout_constraintStart_toEndOf="@id/detail_pet_photo" />

    <EditText
        android:id="@+id/detail_pet_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/pet_name_hint"
        app:layout_constraintTop_toBottomOf="@id/detail_pet_photo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/detail_pet_age"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="@string/pet_age_hint"
        android:inputType="number"
        app:layout_constraintTop_toBottomOf="@id/detail_pet_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/save_pet_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/save_pet"
        app:layout_constraintTop_toBottomOf="@id/detail_pet_age"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/delete_pet_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp"
        android:text="@string/delete_pet"
        app:layout_constraintTop_toBottomOf="@id/detail_pet_age"
        app:layout_constraintStart_toEndOf="@id/save_pet_button" />

    <TextView
        android:id="@+id/events_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/events_title"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
        app:layout_constraintTop_toBottomOf="@id/save_pet_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/add_event_button" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/add_event_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/add_event"
        app:layout_constraintTop_toTopOf="@id/events_title"
        app:layout_constraintBottom_toBottomOf="@id/events_title"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/detail_events_list"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/events_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>


